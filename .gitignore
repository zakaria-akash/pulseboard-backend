# =============================================================================
# PulseBoard Backend — .gitignore
# Node.js · TypeScript · Express · MongoDB · npm
# =============================================================================


# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================
.env
.env.*
!.env.example
!.env.test.example
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets/
.secrets/


# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz


# =============================================================================
# BUILD OUTPUT
# =============================================================================
dist/
build/
out/
*.js.map
*.d.ts.map


# =============================================================================
# TYPESCRIPT
# =============================================================================
*.tsbuildinfo
tsconfig.tsbuildinfo


# =============================================================================
# TEST & COVERAGE
# =============================================================================
coverage/
.nyc_output/
*.lcov
test-results/
junit.xml


# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# =============================================================================
# RUNTIME & PROCESS
# =============================================================================
pids/
*.pid
*.seed
*.pid.lock


# =============================================================================
# CACHE
# =============================================================================
.npm/
.eslintcache
.stylelintcache
.prettiercache
.cache/
.parcel-cache/
.turbo/
.rollup.cache/
.swc/


# =============================================================================
# OS GENERATED
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Windows reserved device names — Git cannot index these on Windows
# because the OS intercepts them before the filesystem sees them.
# (nul = null device, equivalent to /dev/null on Unix)
nul
nul.txt
con
prn
aux

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


